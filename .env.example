# Server port
PORT=3000

# "local" → STORAGE_PATH is a local or UNC path (recommended for Windows)
# "smb"   → same, but server also runs `net use` on startup to authenticate
STORAGE_TYPE=local

# Path to the recordings root.
# Local example:  ./video_example
# UNC example:    \\192.168.1.100\cctv
STORAGE_PATH=./video_example

# SMB credentials (only used when STORAGE_TYPE=smb)
# Never commit real credentials — keep them in .env only
SMB_HOST=192.168.1.x
SMB_SHARE=cctv
SMB_USERNAME=user
SMB_PASSWORD=secret
