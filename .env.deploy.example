# NAS deploy config — copy to .env.deploy and fill in your values
NAS_HOST=192.168.1.x          # IP or hostname of your Synology NAS
NAS_USER=admin                # SSH user on the NAS
NAS_DIR=/volume1/docker/cctv-ui  # Directory on NAS to deploy to
SSH_KEY=~/.ssh/id_rsa         # Path to SSH private key (leave empty to use ssh-agent)
IMAGE=ghcr.io/atotmakov/cctv-ui:latest  # Docker image to pull (override if needed)
